rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────
    function isAuth()   { return request.auth != null; }
    function uid()      { return request.auth.uid; }
    function userDoc()  {
      return exists(/databases/$(database)/documents/users/$(uid()))
        ? get(/databases/$(database)/documents/users/$(uid())).data
        : null;
    }
    function role()     {
      return isAuth() && userDoc() != null && userDoc().role != null
        ? userDoc().role
        : 'public';
    }
    function isAdmin()  { return role() == 'admin'; }
    function isSheikh() { return role() == 'sheikh'; }
    function mySheikhId() { return userDoc().sheikhId; }

    // ── Users ────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth() && (uid() == userId || isAdmin());
      allow create: if isAuth() && uid() == userId;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Sheikhs ──────────────────────────────────────────────
    match /sheikhs/{sheikhId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || (
        isSheikh() &&
        sheikhId == mySheikhId() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['totalEvaluated'])
      );
    }

    // ── Competitions ─────────────────────────────────────────
    match /competitions/{compId} {
      allow read:  if true;
      allow write: if isAdmin();

      // Students
      match /students/{studentId} {
        allow read:  if isAdmin() || isSheikh();
        allow create: if true;
        allow update: if isAdmin() || (
          isSheikh() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']) &&
          request.resource.data.status == 'evaluated'
        );
        allow delete: if isAdmin();
      }

      // Scores — immutable once written
      match /scores/{scoreId} {
        allow read: if
          resource.data.isPublished == true ||
          isAdmin() ||
          (isSheikh() && resource.data.sheikhId == mySheikhId());

        allow create: if
          isSheikh() &&
          request.resource.data.sheikhId == mySheikhId() &&
          request.resource.data.isPublished == false;

        allow update: if isAdmin();
        allow delete: if false;
      }

      // Sessions
      match /sessions/{sessionId} {
        allow read: if isAdmin() ||
          (isSheikh() && resource.data.sheikhId == mySheikhId());
        allow write: if isAdmin();
      }
    }

    // ── Audit Logs ───────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read:          if isAdmin();
      allow create:        if isAuth();
      allow update, delete: if false;
    }
  }
}
