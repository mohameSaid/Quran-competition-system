rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────
    function isAuth()   { return request.auth != null; }
    function uid()      { return request.auth.uid; }
    function userDoc()  {
      return exists(/databases/$(database)/documents/users/$(uid()))
        ? get(/databases/$(database)/documents/users/$(uid())).data
        : null;
    }
    function role()     {
      return isAuth() && userDoc() != null && userDoc().role != null
        ? userDoc().role
        : 'public';
    }
    function isAdmin()  { return role() == 'admin'; }
    function isSheikh() { return role() == 'sheikh'; }
    function mySheikhId() { return userDoc().sheikhId; }

    // ── Platform helpers ─────────────────────────────────────
    // Immutable audit fields must never change after creation.
    function keepsCreator() {
      return request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
    }
    // A self-registrant owns the person doc whose id equals their uid.
    function ownsPerson(pid) { return isAuth() && uid() == pid; }

    // ── Users ────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth() && (uid() == userId || isAdmin());
      allow create: if isAdmin() || (isAuth() && uid() == userId);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Sheikhs (judges) ─────────────────────────────────────
    match /sheikhs/{sheikhId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || (
        isSheikh() &&
        sheikhId == mySheikhId() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['totalEvaluated'])
      );
    }

    // ── Memorizers (محفّظون) ─────────────────────────────────
    match /memorizers/{memorizerId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── Previous-competition data (بيانات المسابقات السابقة) ──
    // تحوي أرقام هواتف — القراءة والكتابة للأدمن فقط.
    match /previousParticipations/{id} {
      allow read:   if isAdmin();
      allow write:  if isAdmin();
    }

    // ── Home page CMS content (محتوى الصفحة الرئيسية) ─────────
    match /siteContent/{docId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ═════════════════════════════════════════════════════════
    // PLATFORM COLLECTIONS (Phase 1)
    // ═════════════════════════════════════════════════════════

    // ── Persons (the unified record — "Person First") ────────
    match /persons/{personId} {
      // Owner or staff may read; person docs may hold contact data.
      allow read: if ownsPerson(personId) || isAdmin() || isSheikh();
      // Self-registration (uid == personId) or admin-created.
      allow create: if isAdmin()
        || (ownsPerson(personId)
            && request.resource.data.accountUid == uid()
            && request.resource.data.createdBy == uid());
      // Owner may edit their own profile (not audit fields); admin any.
      allow update: if isAdmin()
        || (ownsPerson(personId) && keepsCreator());
      allow delete: if isAdmin();

      // Role assignments per person: persons/{id}/roles/{roleType}
      match /roles/{roleType} {
        allow read: if ownsPerson(personId) || isAdmin();
        // Self may request a role, but only in 'pending' state.
        allow create: if isAdmin()
          || (ownsPerson(personId) && request.resource.data.status == 'pending');
        // Approving / suspending / revoking is an admin action.
        allow update, delete: if isAdmin();
      }
    }

    // ── Master Data (reference lists — read-only to everyone) ─
    match /masterData/{domain}/items/{itemId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Role policies (runtime RBAC overrides) ───────────────
    match /rolePolicies/{roleId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Programs (competition, circle, course, event, camp) ──
    match /programs/{programId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Enrollments (Person ↔ Program) ───────────────────────
    match /enrollments/{enrollmentId} {
      allow read: if isAdmin() || isSheikh()
        || (isAuth() && resource.data.personId == uid());
      // A person may enroll themselves in 'pending' state.
      allow create: if isAdmin()
        || (isAuth()
            && request.resource.data.personId == uid()
            && request.resource.data.status == 'pending');
      allow update, delete: if isAdmin();
    }

    // ── Notifications (per recipient) ────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.recipientPersonId == uid());
      allow create: if isAdmin();
      // Recipient may only flip their own notification to 'read'.
      allow update: if isAdmin()
        || (isAuth()
            && resource.data.recipientPersonId == uid()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin();
    }

    // ── Audit logs (append-only, admin-readable) ─────────────
    match /auditLogs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── Competitions ─────────────────────────────────────────
    match /competitions/{compId} {
      allow read:  if true;
      allow write: if isAdmin();

      match /students/{studentId} {
        allow read:  if isAdmin() || isSheikh();
        allow create: if true;
        allow update: if isAdmin() || (
          isSheikh() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']) &&
          request.resource.data.status == 'evaluated'
        );
        allow delete: if isAdmin();
      }

      match /scores/{scoreId} {
        allow read: if
          resource.data.isPublished == true ||
          isAdmin() ||
          (isSheikh() && resource.data.sheikhId == mySheikhId());

        allow create: if
          isSheikh() &&
          request.resource.data.sheikhId == mySheikhId() &&
          request.resource.data.isPublished == false;

        allow update: if isAdmin();
        allow delete: if false;
      }

      match /sessions/{sessionId} {
        allow read: if isAdmin() ||
          (isSheikh() && resource.data.sheikhId == mySheikhId());
        allow write: if isAdmin();
      }
    }
  }
}
